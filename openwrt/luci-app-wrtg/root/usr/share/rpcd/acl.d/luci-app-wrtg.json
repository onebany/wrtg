{
	"luci-app-wrtg": {
		"description": "Grant access to wrtg LuCI app",
		"read": {
			"file": {
				"/etc/wrtg/config": [ "read" ],
				"/etc/wrtg/version": [ "read" ],
				"/etc/wrtg/README.md": [ "read" ],
				"/etc/wrtg/dc-ips.txt": [ "read" ],
				"/etc/wrtg/dc-ips-learned.txt": [ "read" ]
			}
		},
		"write": {
			"file": {
				"/etc/wrtg/config": [ "write" ],
				"/etc/wrtg/dc-ips.txt": [ "write" ],
				"/etc/wrtg/dc-ips-learned.txt": [ "write" ]
			}
		}
	}
}
