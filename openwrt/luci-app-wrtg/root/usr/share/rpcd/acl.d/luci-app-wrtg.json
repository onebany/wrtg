{
	"luci-app-wrtg": {
		"description": "Grant access to wrtg LuCI app",
		"read": {
			"file": {
				"/etc/wrtg/config": [ "read" ],
				"/etc/wrtg/version": [ "read" ],
				"/etc/wrtg/docs/ARCHITECTURE.md": [ "read" ],
				"/etc/wrtg/docs/DEVELOPMENT.md": [ "read" ],
				"/etc/wrtg/docs/CF_WORKER_SETUP.md": [ "read" ],
				"/etc/wrtg/docs/CF_PROXY.md": [ "read" ]
			}
		},
		"write": {
			"file": {
				"/etc/wrtg/config": [ "write" ]
			}
		}
	}
}
